  "info": {
    "_postman_id": "cba2cdb6-11a6-4ad6-8730-ba2a8b8822f8",
    "name": "FullStory Sessions API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The FullStory Sessions API allows developers to retrieve session replay URLs for specific users and access session event data. By querying with a user email address or user ID, the API returns a list of session URLs that can be used to view recorded sessions in the FullStory platform. The API also supports AI-powered session summaries through configurable summary prompt profiles.\n\nContact Support:\n Name: FullStory Support",
      "type": "text/plain"
    }
  }
