    {
      "id": "50f72f77-198c-4e4c-ae0e-6dd4d210408b",
      "name": "Session Summaries",
      "description": {
        "content": "Generate AI-powered summaries of sessions using configurable prompt profiles. Summaries can be customized with pre and post prompts, response schemas, and session slicing options.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "ac393e64-adf5-4ad0-a502-f63c7896b5e3",
          "name": "Generate AI session summary",
          "request": {
            "name": "Generate AI session summary",
            "description": {
              "content": "Returns a generative AI summarization of the specified session using the supplied prompt summary profile. The config_profile_id parameter specifies the prompt profile that defines both the prompting instructions and session context configuration. Summary profiles support custom pre and post prompts, structured response schemas, and session slicing to trim event data.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v2",
                "sessions",
                ":sessionId",
                "summary"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "config_profile_id",
                  "value": "<string>",
                  "description": "(Required) The ID of the summary prompt profile to use for generating the AI session summary"
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "sessionId",
                  "description": "(Required) The session identifier, URL encoded"
