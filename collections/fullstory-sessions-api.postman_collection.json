            "name": "Get session events",
            "description": {
              "content": "Returns the full set of captured events for a specified session, including page views, clicks, custom events, and other interactions recorded during the session.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v2",
                "sessions",
                ":sessionId",
                "events"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "sessionId",
                  "description": "(Required) The session identifier, URL encoded"
                }
              ]
